<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE topic PUBLIC "-//OASIS//DTD DITA Topic//EN" "topic.dtd">
<topic id="spanned-table">
  <title>Spanned marker table</title>
  <body>
    <table>
      <title>Combined positions</title>
      <tgroup cols="4">
        <colspec colname="c1" colnum="1"/>
        <colspec colname="c2" colnum="2"/>
        <colspec colname="c3" colnum="3"/>
        <colspec colname="c4" colnum="4"/>
        <thead>
          <row>
            <entry>One</entry>
            <entry>Two</entry>
            <entry>Three</entry>
            <entry>Four</entry>
          </row>
        </thead>
        <tbody>
          <row>
            <entry namest="c1" nameend="c2">Horizontal pair</entry>
            <entry morerows="1">Vertical pair</entry>
            <entry>R1C4</entry>
          </row>
          <row>
            <entry>R2C1</entry>
            <entry>R2C2</entry>
            <entry>R2C4</entry>
          </row>
          <row>
            <entry morerows="1">Left vertical</entry>
            <entry namest="c2" nameend="c4">Wide lower row</entry>
          </row>
          <row>
            <entry>R4C2</entry>
            <entry>R4C3</entry>
            <entry>R4C4</entry>
          </row>
        </tbody>
      </tgroup>
    </table>
  </body>
</topic>
