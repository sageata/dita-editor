<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE topic PUBLIC "-//OASIS//DTD DITA Topic//EN" "topic.dtd">
<topic id="noncanonical-colspec">
  <title>Varied column declarations</title>
  <body>
    <table>
      <tgroup cols="3">
        <colspec colnum="1" colname='code'/>
        <colspec colwidth="3*" colname='details' colnum="2"/>
        <colspec colname='status' colnum="3"/>
        <tbody>
          <row>
            <entry>A1</entry>
            <entry>First fictional detail</entry>
            <entry>Ready</entry>
          </row>
          <row>
            <entry>B2</entry>
            <entry>Second fictional detail</entry>
            <entry>Paused</entry>
          </row>
        </tbody>
      </tgroup>
    </table>
  </body>
</topic>
