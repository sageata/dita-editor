<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE topic PUBLIC "-//OASIS//DTD DITA Topic//EN" "topic.dtd">
<topic id="ordinary-table">
  <title>Ordinary marker table</title>
  <body>
    <table>
      <title>Marker positions</title>
      <tgroup cols="3">
        <colspec colname="c1" colnum="1"/>
        <colspec colname="c2" colnum="2"/>
        <colspec colname="c3" colnum="3"/>
        <thead>
          <row>
            <entry>Shape</entry>
            <entry>Color</entry>
            <entry>Position</entry>
          </row>
        </thead>
        <tbody>
          <row>
            <entry>Square</entry>
            <entry>Gray</entry>
            <entry>Left</entry>
          </row>
          <row>
            <entry>Circle</entry>
            <entry>Blue</entry>
            <entry>Right</entry>
          </row>
        </tbody>
      </tgroup>
    </table>
  </body>
</topic>
