<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE topic PUBLIC "-//OASIS//DTD DITA Topic//EN" "topic.dtd">
<topic id="qa_noncanonical_colspec">
  <title>Noncanonical Colspec</title>
  <body>
    <table>
      <tgroup cols="2">
        <colspec colname="c1" colnum="1"/>
        <colspec colname="c2" colnum="2" colwidth="2*"/>
        <tbody>
          <row>
            <entry>a</entry>
            <entry>b</entry>
          </row>
          <row>
            <entry>c</entry>
            <entry>d</entry>
          </row>
        </tbody>
      </tgroup>
    </table>
  </body>
</topic>
